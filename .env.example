# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/doc_intelligence

# Server
HOST=0.0.0.0
PORT=8000

# LLM Provider
# Options: openai-compatible, ollama
LLM_PROVIDER=openai-compatible
LLM_MODEL=deepseek-v4-flash
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# Ollama (if using LLM_PROVIDER=ollama)
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# Embeddings
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSION=384

# AGE database (separate container for graph storage)
AGE_DATABASE_URL=postgresql+asyncpg://postgres:postgres@age:5432/doc_graph

# Graph extraction (optional, defaults shown)
GRAPH_EXTRACTION_ENABLED=true
GRAPH_CHUNKS_TO_COMBINE=1
GRAPH_STRONG_ENTITY_TYPES=Organization,Location,Date,Money,Event,Document,Concept,Skill,Profession
GRAPH_MAX_TRAVERSAL_DEPTH=2
GRAPH_ENTITY_DEDUP_THRESHOLD=0.95
CHUNK_TOKEN_SIZE=512
CHUNK_TOKEN_OVERLAP=50
